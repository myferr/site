---
const { TitleName } = Astro.props;

import "../../styles/globals.css";
const publicDirectory = "../../../public";

import Cursor from './cursor/Cursor.astro';
---

<html lang="en">
  <head id="Head">
    <link
      rel="shortcut icon"
      href=`${publicDirectory}/favicon.png`
      type="image/x-icon"
    />
    <title>{TitleName}</title>
  </head>
  <body>
    <Cursor/>
    <slot />
  </body>
</html>
