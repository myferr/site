---
import Layout from "../components/layout/Layout.astro";
import MetaTags from "../components/layout/MetaTags.astro";

import Nav from "../components/layout/ui/Nav.astro";

import { Button } from "../components/ui/button.tsx";
import { ArrowRight, Quote } from "lucide-react";
import { Card, CardContent } from "../components/ui/card";
import { Avatar } from "../components/ui/avatar";

import { testimonials } from "../lib/testimonials.ts";
---

<MetaTags
  TitleName="MyferIsADev"
  Description="A Florida-based developer with 4+ years of experience and a passion for web development."
/>

<Layout TitleName="MyferIsADev">
  <Nav />
  <main class="w-full py-12 md:py-24 lg:py-32 xl:py-48 bg-background">
    <div class="container px-4 md:px-6">
      <div
        class="grid gap-6 lg:grid-cols-[1fr_400px] lg:gap-12 xl:grid-cols-[1fr_600px]"
      >
        <div class="flex flex-col justify-center space-y-4">
          <div class="space-y-2">
            <h1
              class="text-3xl font-bold tracking-tighter md:mt-5 sm:text-5xl xl:text-6xl/none"
            >
              Hi, I'm Dennis.
            </h1>
            <p class="max-w-[600px] text-muted-foreground md:text-xl">
              I'm a developer with 4+ years of experience and passionate about
              creating beautiful and functional web experiences. With expertise
              in software & website development, I bring ideas to life through
              code.
            </p>
          </div>
          <div class="flex flex-col gap-2 min-[400px]:flex-row">
            <Button className="inline-flex items-center justify-center">
              View My Work
              <ArrowRight className="ml-2 h-4 w-4" />
            </Button>
            <Button variant="outline">Contact Me</Button>
          </div>
        </div>
        <div class="flex items-center justify-center">
          <div class="relative rounded-lg bg-slate-900 p-2">
            <div class="relative flex text-center">
              <div class="flex pl-3.5 pt-3">
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="-ml-0.5 mr-1.5 h-3 w-3 text-red-500/20"
                >
                  <circle r="12" cy="12" cx="12"></circle>
                </svg><svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="-ml-0.75 mr-1.5 h-3 w-3 text-yellow-500/20"
                >
                  <circle r="12" cy="12" cx="12"></circle>
                </svg><svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="-ml-0.75 mr-1.5 h-3 w-3 text-green-500/20"
                >
                  <circle r="12" cy="12" cx="12"></circle>
                </svg>
              </div><span
                class="absolute inset-x-0 top-2 text-xs text-slate-500"
                >Introduction.ts</span
              >
            </div>
            <div class="mt-5 space-y-1.5 px-5 pb-10">
              <p
                class="mt-4 font-mono text-xs font-normal tracking-wide text-violet-400"
                id="code"
              >
                <span class="text-pink-400">import</span>
                {"{ Human }"}
                <span class="text-pink-400">from</span>
                <span class="text-blue-400">{"./species.ts"}</span>
                <br /><br />
                <span class="text-pink-400">class</span>
                Dennis <span class="text-blue-400">extends</span>
                <span class="text-pink-400">Human</span>
                <span class="text-blue-400">
                  {"{"}
                </span>
                <br />
                <span class="ml-4"
                  >name = <span class="text-blue-400">"Dennis";</span>
                </span>
                <br />
                <span class="ml-4">
                  social = <span class="text-blue-400">{"{"}</span>
                </span>
                <br />
                <span class="ml-8">
                  github = <span class="text-blue-400"
                    >"https://github.com/myferr/";</span
                  >
                </span>
                <span class="ml-8">
                  guilded = <span class="text-blue-400"
                    >"https://guilded.com/u/myferr/";</span
                  >
                </span>
                <span class="ml-8">
                  twitter = <span class="text-blue-400"
                    >"https://x.com/myferisadev/";</span
                  >
                </span>
                <span class="ml-8">
                  bsky = <span class="text-blue-400"
                    >"https://bsky.app/profile/myferr.bsky.social";</span
                  >
                </span>
                <br />
                <span class="ml-4">
                  <span class="text-blue-400">{"}"}</span>
                </span>
                <br />
                <br />
                <span class="ml-4">
                  <span class="text-pink-400"
                    >greet() <span class="text-blue-400">{"{"}</span></span
                  >
                  <br />
                  <span class="ml-8">
                    console.log(<span class="text-blue-400"
                      >`Hello, my name is $<span class="text-pink-400"
                        >{"{this.name}"}</span
                      >!`</span
                    >);
                  </span>
                  <br />
                  <span class="text-blue-400">{"}"}</span>
                  <br />
                  <br />
                  <span class="text-pink-400"> const </span> dennis = <b>new</b>
                  <span class="text-pink-400">Dennis</span>;
                  <br />
                  <span class="text-pink-400"> dennis.greet(); </span>
                  <br />
                </span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-12">
      <section
        class="w-full pt-12 md:pt-24 lg:pt-32 bg-gradient-to-r from-purple-700 to-indigo-800 text-white pb-6 md:pb-6 lg:pb-10"
      >
        <h2
          class="text-3xl font-bold tracking-tighter sm:text-5xl text-center mb-12"
        >
          What People Are Saying
        </h2>
        <div class="container px-4 md:px-6">
          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 content-center gap-8"
          >
            {
              testimonials.map((testimonial, index) => (
                <Card
                  key={index}
                  className="bg-white/10 hover:bg-white/15 backdrop-blur-lg border-none text-white cursor-pointer hover:-translate-y-3 transition-all duration-500 hover:scale-[103%]"
                >
                  <CardContent className="p-6">
                    <Quote className="w-10 h-10 mb-4 text-purple-300" />
                    <p class="mb-4 italic">{testimonial.content}</p>
                    <div class="flex items-center">
                      <Avatar className="h-12 w-12 mr-4">
                        <img src={testimonial.avatar} alt="" />
                      </Avatar>
                      <div>
                        <span class="font-semibold">{testimonial.name}</span>
                        <p class="text-sm text-purple-300">
                          {testimonial.role}
                        </p>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))
            }
          </div>
        </div>
        <div class="text-center">
          <a
            href="mailto:registeraquote.swung661@passinbox.com"
            target="_blank"
          >
            <Button variant={"secondary"} className="mt-20">
              Get your quote up there!<ArrowRight className="mr-2 h-4 w-4" />
            </Button>
          </a>
        </div>
      </section>
    </div>
  </main>
</Layout>
